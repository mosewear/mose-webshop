# Environment Variables Template
# Copy this to .env.local and fill in your actual values

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SendCloud
SENDCLOUD_PUBLIC_KEY=""
SENDCLOUD_SECRET_KEY=""

# Supabase (REQUIRED for checkout!)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Other
CRON_SECRET=""
INTERNAL_API_SECRET=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"
NEXT_PUBLIC_POSTHOG_KEY=""
RESEND_API_KEY=""

# Trustpilot
# Unique Automatic Feedback Service (AFS) BCC address. Found in Trustpilot
# Business portal > Get reviews > Invitation settings > BCC method. When set,
# our "order delivered" e-mail BCCs this address so Trustpilot fires its own
# review invitation after the delay configured in the Trustpilot portal.
# Leave empty to disable Trustpilot invitations entirely.
TRUSTPILOT_AFS_BCC_EMAIL=""
# Optional: used by the footer widget to decide when to show the Trustpilot
# rating badge. The widget only renders once we hit this threshold.
TRUSTPILOT_REVIEW_COUNT="0"
TRUSTPILOT_MIN_REVIEWS="30"

# Instagram Feed (managed via /admin/instagram).
# Token + business account id are stored in the instagram_credentials
# table; only the Meta app credentials live in env so the monthly
# token-refresh cron can call /oauth/access_token. Both optional —
# without them, /api/instagram/refresh-token returns 503 cleanly and
# you can still paste a fresh token by hand in /admin/instagram.
META_APP_ID=""
META_APP_SECRET=""
