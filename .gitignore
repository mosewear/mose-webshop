# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# one-shot exports that may contain customer PII
trustpilot-invitations-*.csv

# Photoshoot 2026 originals — large RAW JPGs and source ZIPs, not for git.
# Optimised WebP variants live on Supabase Storage; static fallbacks live in /public.
photoshoot-2026/*.jpg
photoshoot-2026/*.JPG
photoshoot-2026/*.jpeg
photoshoot-2026/*.JPEG
photoshoot-2026/*.zip
photoshoot-2026/*.ZIP

# macOS Finder duplicate-on-paste artefacts (e.g. "foo 2.sql"). These
# are never intentional and have caused accidental commits before.
*\ [0-9].*
*\ [0-9][0-9].*
